{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quest4bugs.local/contracts/media_pipeline/zukan_fetch_request.schema.json",
  "title": "ZukanFetchRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "requestId", "gapId", "intent", "speciesId",
    "variant", "jaName", "acceptedScientificName", "synonyms",
    "taxonRank", "family", "preferredRecordType",
    "allowedMediaLicenses", "excludedMediaIds", "currentEntryHash",
    "emitMode"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "requestId": { "type": "string", "pattern": "^[0-9a-f]{64}:[0-9]+$" },
    "gapId": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "intent": {
      "enum": ["missing", "replacement", "new_species", "variant_missing"]
    },
    "speciesId": { "type": "string", "minLength": 1 },
    "variant": { "type": "string", "minLength": 1 },
    "jaName": { "type": "string", "minLength": 1 },
    "acceptedScientificName": { "type": "string", "minLength": 1 },
    "synonyms": {
      "type": "array", "items": { "type": "string", "minLength": 1 }
    },
    "taxonRank": { "type": "string", "minLength": 1 },
    "family": { "type": "string", "minLength": 1 },
    "preferredRecordType": { "type": "string", "minLength": 1 },
    "allowedMediaLicenses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["CC0-1.0", "PDM-1.0", "CC-BY-4.0", "CC-BY-SA-4.0"]
      }
    },
    "excludedMediaIds": {
      "type": "array", "items": { "type": "string", "minLength": 1 }
    },
    "currentEntryHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "emitMode": { "const": "staging_only" }
  }
}
